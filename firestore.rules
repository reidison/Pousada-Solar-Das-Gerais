/**
 * @fileOverview Firestore Security Rules for Pousada Solar das Gerais.
 *
 * Core Philosophy:
 * This ruleset provides open read access to guest information, minibar menus, and service categories,
 * allowing any user (signed in or not) to retrieve this data. Writes are completely
 * disallowed to prevent unauthorized modifications, as this is considered static
 * data managed internally. This is suitable for a system where guest information
 * and service details are intended to be publicly available.
 *
 * Data Structure:
 * - /guest_info/{guestInfoId}: Stores general information for guests.
 * - /minibar_menus/{minibarMenuId}: Stores minibar menu information.
 * - /service_categories/{serviceCategoryId}: Stores categories of useful services.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows anyone to read guest information, but prevents all writes.
     * @path /guest_info/{guestInfoId}
     * @allow (get, list) Any user can read guest information.
     * @deny (create, update, delete) No user can create, update, or delete guest information.
     * @principle Allows public read access to guest information.
     */
    match /guest_info/{guestInfoId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows anyone to read minibar menus, but prevents all writes.
     * @path /minibar_menus/{minibarMenuId}
     * @allow (get, list) Any user can read minibar menus.
     * @deny (create, update, delete) No user can create, update, or delete minibar menus.
     * @principle Allows public read access to minibar menus.
     */
    match /minibar_menus/{minibarMenuId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Allows anyone to read service categories, but prevents all writes.
     * @path /service_categories/{serviceCategoryId}
     * @allow (get, list) Any user can read service categories.
     * @deny (create, update, delete) No user can create, update, or delete service categories.
     * @principle Allows public read access to useful services information.
     */
    match /service_categories/{serviceCategoryId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
